# GitHub OAuth App credentials — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Full public URL of this server (used as the OAuth callback base)
# Must match the Authorization callback URL in your GitHub OAuth App
SERVER_URL=https://your-tailscale-address

# Secret for signing JWT cookies — generate with: openssl rand -hex 32
JWT_SECRET=

# Origin of the PWA frontend (for CORS)
CLIENT_URL=https://your-server-address

# Server port (default: 3000)
PORT=3000
